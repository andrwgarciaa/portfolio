---
import background from "../assets/background.svg";

import "../styles/global.css";
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content="Andrew Garcia's personal website" />
    <meta
      name="keywords"
      content="Andrew Garcia, Software Engineer, Web Developer, Portfolio"
    />
    <meta name="author" content="Andrew Garcia" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Basic:ital,wght@0,400;0,500;0,600;0,700&display=swap"
      rel="stylesheet"
    />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <title>Andrew Garcia</title>
  </head>
  <body>
    <img
      id="background"
      src={background.src}
      alt=""
      fetchpriority="high"
      class="fixed pointer-events-none left-0 top-0 w-full h-full blur-[50px] rotate-180"
    />

    <slot />
  </body>
</html>

<style>
  html,
  body {
    margin: 0;
    width: 100%;
    height: 100%;
    font-family:
      "Basic",
      system-ui,
      -apple-system,
      BlinkMacSystemFont,
      "Segoe UI",
      sans-serif;
    background-color: #ffffff;
    color: #050505;
  }

  #background {
    will-change: transform;
    animation: floatBackground 30s ease-in-out infinite;
  }

  @keyframes floatBackground {
    0%,
    100% {
      transform: translate(0px, 0px) rotate(180deg) skewX(0deg);
    }
    33% {
      transform: translate(20px, -12px) rotate(230deg) skewX(-5deg);
    }
    66% {
      transform: translate(-12px, 10px) rotate(177deg) skewX(10deg);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    #background {
      animation: none;
    }
  }

  @media (prefers-color-scheme: dark) {
    html,
    body {
      background-color: #050505;
      color: #f7f7f7;
    }
  }
</style>
